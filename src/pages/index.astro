---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;

const categories = [
  { title: 'Skills',       count: '12 skills',       icon: '✦', href: `${base}skills/`,    accent: true },
  { title: 'Hooks',        count: '8 hooks',         icon: '↯', href: `${base}hooks/`,     accent: false },
  { title: 'Commandes /',  count: '24 cmds',         icon: '/', href: `${base}commands/`,  accent: false },
  { title: 'MCP Servers',  count: '15 serveurs',     icon: '◈', href: `${base}hooks/`,     accent: false },
  { title: 'Settings',     count: '30+ options',     icon: '⚙', href: `${base}claude-md/`, accent: false },
  { title: 'Prompts',      count: "Par cas d'usage", icon: '✎', href: `${base}tips/`,      accent: false },
];

const tilts = ['tilt-l', 'tilt-r', 'tilt-l', 'tilt-r', 'tilt-l', 'tilt-r'];
const boxes = ['sketch-box-1', 'sketch-box-2', 'sketch-box-3', 'sketch-box-4', 'sketch-box-5', 'sketch-box-6'];

const titleAlts = [
  '« Guide Claude »',
  '« Claude Code, en clair »',
  '« Cheatsheet Claude Code »',
  '« Le petit manuel »',
];
---

<Layout title="ai-coding-cheatsheet — Le guide Claude Code">
  <Navbar />

  <header class="px-5 pt-10 sm:pt-14 pb-2 text-center">
    <h1 class="font-hand font-bold text-[44px] sm:text-[56px] text-[color:var(--color-ink)] leading-[1.1] mb-3">
      <span class="highlight-marker">Le guide Claude Code.</span>
    </h1>
    <p class="font-hand-body text-base sm:text-lg text-[color:var(--color-ink-soft)] mb-3">
      Référence rapide : skills, hooks, commandes, MCP, settings.
    </p>
    <div class="font-hand text-[15px] text-[color:var(--color-ink-faint)] flex gap-3.5 justify-center flex-wrap">
      <span>alts :</span>
      {titleAlts.map((alt, i) => (
        <span>{i > 0 ? '· ' : ''}{alt}</span>
      ))}
    </div>
  </header>

  <!-- CTA row -->
  <div class="text-center mt-6 mb-8 px-5">
    <div class="inline-flex items-center gap-3 flex-wrap justify-center">
      <a
        href={`${base}getting-started/`}
        class="sketch-box sketch-box-thick sketch-box-4 inline-flex items-center gap-2 px-[18px] py-2 font-hand font-bold text-[22px] text-[color:var(--color-ink)] hover:-translate-y-0.5 transition-transform"
        style="background: #fef4a8; transform: rotate(-1.2deg);"
      >
        → Démarrer en 4 min
      </a>
      <span class="font-hand-body text-[14px] text-[color:var(--color-ink-faint)]">
        ou explore ci-dessous
      </span>
    </div>
  </div>

  <main class="max-w-5xl mx-auto px-5 sm:px-10 pb-20">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {categories.map((c, i) => (
        <a
          href={c.href}
          class:list={[
            'sketch-box', boxes[i % boxes.length], tilts[i % tilts.length],
            'block p-5 pb-4 bg-white hover:bg-[color:var(--color-paper)] transition-all hover:-translate-y-0.5',
          ]}
        >
          <div class:list={[
            'font-mono text-[22px] mb-1.5',
            c.accent ? 'text-[color:var(--color-claude-orange)]' : 'text-[color:var(--color-ink)]',
          ]}>
            {c.icon}
          </div>
          <div class="font-hand font-bold text-[24px] text-[color:var(--color-ink)] leading-tight mb-1">
            {c.title}
          </div>
          <div class="font-mono text-[11px] text-[color:var(--color-ink-faint)]">
            {c.count}
          </div>
        </a>
      ))}
    </div>
  </main>

  <Footer />
</Layout>
