---
interface Props {
  title: string;
  description: string;
  breadcrumb?: string;
  highlight?: string;
}

const { title, description, breadcrumb, highlight } = Astro.props;
// If highlight is provided, split title around first occurrence. Otherwise highlight the whole title.
let before = '', marked = title, after = '';
if (highlight && title.includes(highlight)) {
  const idx = title.indexOf(highlight);
  before = title.slice(0, idx);
  marked = highlight;
  after = title.slice(idx + highlight.length);
}
---

<div class="border-b border-[color:var(--color-ink-faint)]/40 bg-[color:var(--color-paper)]">
  <div class="max-w-6xl mx-auto px-5 sm:px-7 pt-6 pb-8">
    {breadcrumb && (
      <div class="font-mono text-[10px] text-[color:var(--color-ink-faint)] mb-3">
        {breadcrumb}
      </div>
    )}
    <h1 class="font-hand font-bold text-[34px] sm:text-[40px] text-[color:var(--color-ink)] leading-[1.1] mb-2">
      {before}<span class="highlight-marker">{marked}</span>{after}
    </h1>
    <p class="font-hand-body text-[color:var(--color-ink-soft)] max-w-2xl text-[15px] leading-relaxed">
      {description}
    </p>
  </div>
</div>
