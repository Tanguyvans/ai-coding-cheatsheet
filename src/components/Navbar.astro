---
const base = import.meta.env.BASE_URL;
const pathname = Astro.url.pathname;
const b = base.endsWith('/') ? base : `${base}/`;

const pages = [
  { href: `${b}getting-started/`, label: 'Démarrer' },
  { href: `${b}skills/`, label: 'Skills' },
  { href: `${b}hooks/`, label: 'Hooks' },
  { href: `${b}hooks/`, label: 'MCP' },
  { href: `${b}claude-md/`, label: 'Settings' },
];

function isActive(href: string) {
  return pathname.startsWith(href);
}
---

<nav class="border-b-[1.5px] border-[color:var(--color-ink)] bg-[color:var(--color-paper)] sticky top-0 z-50">
  <div class="max-w-6xl mx-auto px-5 sm:px-7 h-[52px] flex items-center justify-between gap-4">
    <a href={base} class="flex items-center gap-2.5 shrink-0">
      <svg width="22" height="22" viewBox="0 0 22 22" class="block">
        <path d="M 11 2 L 20 18 L 2 18 Z" stroke="var(--color-ink)" stroke-width="1.8" fill="none" stroke-linejoin="round" />
        <circle cx="11" cy="13" r="1.8" fill="var(--color-claude-orange)" />
      </svg>
      <span class="font-hand text-[22px] font-semibold text-[color:var(--color-ink)]">ai-coding-cheatsheet</span>
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex gap-6 font-hand-body text-[15px]">
      {pages.map(p => (
        <a
          href={p.href}
          class:list={[
            'transition-colors pb-0.5',
            isActive(p.href)
              ? 'text-[color:var(--color-claude-orange)] border-b-[1.5px] border-[color:var(--color-claude-orange)]'
              : 'text-[color:var(--color-ink-soft)] hover:text-[color:var(--color-claude-orange)]',
          ]}
        >
          {p.label}
        </a>
      ))}
    </div>

    <div class="hidden md:block sketch-box sketch-box-4 px-2.5 py-1 font-mono text-[11px] text-[color:var(--color-ink-soft)] shrink-0">
      ⌘K rechercher
    </div>

    <!-- Mobile hamburger -->
    <button id="mobile-menu-btn" class="md:hidden p-2 -mr-2 text-[color:var(--color-ink-soft)]" aria-label="Menu">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <!-- Mobile nav -->
  <div id="mobile-menu" class="hidden md:hidden px-5 pb-4 font-hand-body text-[15px]">
    {pages.map(p => (
      <a
        href={p.href}
        class:list={[
          'block py-2',
          isActive(p.href)
            ? 'text-[color:var(--color-claude-orange)]'
            : 'text-[color:var(--color-ink-soft)]',
        ]}
      >
        {p.label}
      </a>
    ))}
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
