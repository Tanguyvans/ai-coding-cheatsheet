---
interface Props {
  bad: string;
  good: string;
  badLabel?: string;
  goodLabel?: string;
}

const { bad, good, badLabel = 'à éviter', goodLabel = 'à faire' } = Astro.props;
---

<div class="grid sm:grid-cols-2 gap-3 mb-4">
  <!-- GOOD (left) -->
  <div
    class="sketch-box sketch-box-3 p-3.5"
    style="background: #f0f5ed; border-color: #2a5a2a;"
  >
    <div class="flex items-center gap-1.5 mb-2">
      <span class="font-hand font-bold text-[18px] text-[#2a5a2a]">
        ✓ {goodLabel}
      </span>
    </div>
    <div class="font-hand-body text-[13px] text-[color:var(--color-ink-soft)] leading-snug [&>code]:bg-[#d6e6d1] [&>code]:text-[#2a5a2a] [&>code]:px-1.5 [&>code]:py-0.5 [&>code]:rounded [&>code]:font-mono [&>code]:text-[0.85em]">
      <Fragment set:html={good} />
    </div>
  </div>

  <!-- BAD (right) -->
  <div
    class="sketch-box sketch-box-4 p-3.5"
    style="background: #f8ecec; border-color: #9a3a3a;"
  >
    <div class="flex items-center gap-1.5 mb-2">
      <span class="font-hand font-bold text-[18px] text-[#9a3a3a]">
        ✗ {badLabel}
      </span>
    </div>
    <div class="font-hand-body text-[13px] text-[color:var(--color-ink-soft)] leading-snug [&>code]:bg-[#ecd6d6] [&>code]:text-[#9a3a3a] [&>code]:px-1.5 [&>code]:py-0.5 [&>code]:rounded [&>code]:font-mono [&>code]:text-[0.85em]">
      <Fragment set:html={bad} />
    </div>
  </div>
</div>
