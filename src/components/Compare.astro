---
interface Props {
  bad: string;
  good: string;
  badLabel?: string;
  goodLabel?: string;
}

const { bad, good, badLabel = 'A eviter', goodLabel = 'Recommande' } = Astro.props;
---

<div class="grid sm:grid-cols-2 gap-3 mb-4">
  <div class="rounded-lg border-2 border-red-200 bg-red-50/50 p-4">
    <div class="flex items-center gap-2 mb-2">
      <span class="flex items-center justify-center w-5 h-5 rounded-full bg-red-100 text-red-500 text-xs font-bold">&times;</span>
      <span class="text-xs font-semibold text-red-400 uppercase tracking-wide">{badLabel}</span>
    </div>
    <div class="text-[0.8125rem] text-sand-700 leading-relaxed [&>code]:bg-red-100/80 [&>code]:text-red-700">
      <Fragment set:html={bad} />
    </div>
  </div>
  <div class="rounded-lg border-2 border-green-200 bg-green-50/50 p-4">
    <div class="flex items-center gap-2 mb-2">
      <span class="flex items-center justify-center w-5 h-5 rounded-full bg-green-100 text-green-600 text-xs font-bold">&check;</span>
      <span class="text-xs font-semibold text-green-500 uppercase tracking-wide">{goodLabel}</span>
    </div>
    <div class="text-[0.8125rem] text-sand-700 leading-relaxed [&>code]:bg-green-100/80 [&>code]:text-green-700">
      <Fragment set:html={good} />
    </div>
  </div>
</div>
