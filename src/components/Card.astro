---
interface Props {
  title: string;
  badge?: string;
}

const { title, badge } = Astro.props;
---

<div class="group bg-white rounded-lg border border-sand-200 p-4 hover:border-claude-orange/30 hover:shadow-md hover:shadow-claude-orange/5 transition-all duration-200 hover:-translate-y-0.5">
  <div class="flex items-start justify-between gap-2 mb-2">
    <h3 class="font-semibold text-sm text-claude-brown group-hover:text-claude-orange transition-colors">{title}</h3>
    {badge && (
      <span class="shrink-0 text-[0.6875rem] font-medium px-2 py-0.5 rounded-full bg-sand-100 text-sand-500">{badge}</span>
    )}
  </div>
  <div class="text-[0.8125rem] text-sand-600 leading-relaxed">
    <slot />
  </div>
</div>
